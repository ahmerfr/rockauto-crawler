# Evomi residential proxy — copy this file to `.evomi.env` and fill in the real
# values from your Evomi dashboard. `.evomi.env` is gitignored; NEVER commit creds.
#
# Dashboard -> Residential -> "Endpoint" / "Proxy Setup" shows the gateway host,
# port, username, and password. Copy them exactly (values below are placeholders).

EVOMI_HOST=core-residential.evomi.com   # gateway host from your dashboard
EVOMI_PORT=1000                          # gateway port from your dashboard
EVOMI_USER=your_proxy_username           # proxy username
EVOMI_PASS=your_proxy_password           # proxy password

# Country targeting. Evomi appends this to the PASSWORD as `_country-XX`.
# MUST stay US: RockAuto serves inflated INTERNATIONAL prices to non-US IPs, so a
# non-US exit corrupts every price. Set to "" only to deliberately allow global.
EVOMI_COUNTRY=US

# --- HARD SAFETY CAP -------------------------------------------------------
# The crawler meters gzipped wire bytes and STOPS before spending past this.
# 14.5 GB * $0.99/GB * 1.17 (Pakistan VAT) ≈ $16.8 — well under the $30 wall.
# Persisted to coverage/bytes_spent.txt so the cap holds across resumed runs.
SP_MAX_GB=14.5
